{
  "name": "react-space-router",
  "description": "Space router bindings for React.",
  "version": "0.6.5",
  "main": "dist/cjs",
  "module": "dist/esm",
  "license": "ICS",
  "repository": {
    "type": "git",
    "url": "git://github.com/humaans/react-space-router.git"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "keywords": [
    "react",
    "browser",
    "clientside",
    "router",
    "history",
    "location",
    "url"
  ],
  "author": "Karolis Narkevicius",
  "scripts": {
    "test": "npm run build && oxlint --ignore-pattern examples --ignore-pattern dist --ignore-pattern docs && prettier --check '**/*.{js,css,yml}' && c8 ava",
    "format": "prettier --write '**/*.{js,css,yml}'",
    "coverage": "c8 --reporter=html ava",
    "build": "node ./tasks/build.js",
    "watch": "node ./tasks/build.js -w",
    "release": "np --no-release-draft",
    "release:beta": "np --tag=beta --no-release-draft",
    "release:docs": "hugo -s docs && gh-pages -d docs/public"
  },
  "dependencies": {
    "space-router": "^0.9.5"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "ava": "^7.0.0",
    "c8": "^11.0.0",
    "execa": "^9.6.1",
    "gh-pages": "^6.3.0",
    "oxlint": "^1.60.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "ava": {
    "files": [
      "test/*.test.*"
    ],
    "extensions": [
      "js",
      "jsx"
    ],
    "require": [
      "@swc-node/register"
    ]
  }
}
